default_platform(:ios)

# Mirrors OKX's iOS app-availability list
# (https://www.okx.com/en-gb/app-availability/ios). The in-app OKX DEX
# is the licensed-availability surface of the app, so we ship in the
# same set of storefronts OKX themselves expose iOS in. Refresh this
# list when OKX revises their page. App Store Connect's modern API
# takes ISO 3166-1 alpha-3 codes (USA, GBR, …) — not the alpha-2 that
# the legacy `deliver` action used.
OKX_AVAILABILITY_ISO3 = %w[
  ARE ATG AIA ARM ARG AUT AUS AZE BRB BEL BGR BHR BMU BOL BRA BHS BWA BLR BLZ
  CAN CAF CHE CIV CHL CMR COL CRI CZE
  DEU DNK DMA DOM ECU EST ESP FIN FRA
  GBR GRD GEO GIN GNQ GRC GTM GNB GUY
  HKG HND HRV HUN IRL ISR ITA JAM JOR JPN
  KEN KGZ KNA KOR KWT CYM KAZ
  LCA LIE LTU LUX LVA
  MAR MDA MNE MDG MKD MLI MAC MLT MUS MEX MYS MOZ
  NER NGA NIC NLD NOR NZL
  OMN PAN PER POL PRT PRY QAT ROU RUS
  SAU SWE SGP SVN SVK SEN SUR SLV
  TCA TJK TKM TUN TUR TTO TWN
  UKR UGA USA URY UZB
  VCT VEN VGB VNM ZAF
].freeze

# To pull current App Store metadata into ios/fastlane/metadata/:
#   cd ios && fastlane deliver download_metadata --force
# (no lane wrapper — `deliver` defaults to upload, the CLI subcommand is the
# only clean way to download.)

platform :ios do
  desc "Upload metadata + screenshots to App Store Connect (no binary)"
  lane :push_metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      run_precheck_before_submit: false,
      overwrite_screenshots: true,
      screenshots_path: "../fastlane/screenshots"
    )
  end

  desc "Show OKX territories Apple doesn't expose as a storefront"
  lane :diff_target do
    require 'spaceship'
    Spaceship::ConnectAPI.login
    bundle_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    client = Spaceship::ConnectAPI.client.tunes_request_client
    params = client.build_params(filter: nil, includes: "territory", limit: 200, sort: nil)
    rows = client.get("v2/appAvailabilities/#{app.id}/territoryAvailabilities", params).body["data"]
    apple_iso3 = rows.map { |r| r["relationships"]["territory"]["data"]["id"] }.to_set
    missing = OKX_AVAILABILITY_ISO3 - apple_iso3.to_a
    UI.message("Apple storefronts: #{apple_iso3.size}; OKX target: #{OKX_AVAILABILITY_ISO3.size}")
    UI.message("OKX codes missing from Apple: #{missing.inspect}")
  end

  desc "Print current App Store availability territories"
  lane :dump_territories do
    require 'spaceship'
    Spaceship::ConnectAPI.login
    bundle_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("Couldn't find app with bundle id #{bundle_id}") if app.nil?
    client = Spaceship::ConnectAPI.client.tunes_request_client
    resp = client.get("v2/appAvailabilities/#{app.id}/territoryAvailabilities", { 'limit' => '200' })
    UI.message("Got #{resp.to_models.length} rows")
    resp.to_models.each { |t| UI.message("  #{t.inspect}") }
  end

  desc "Sync App Store availability territories to OKX_AVAILABILITY_ISO3"
  # ASC's modern flow for territory changes on an existing app:
  #   POST /v1/bulkUpdateAppAvailabilities, type=bulkUpdateAppAvailabilities.
  # The parent `appAvailabilities` resource is CREATE-only — no PATCH,
  # no DELETE — so the bulk endpoint is the only writable path once
  # the app has any availability set. The body must enumerate every
  # existing territoryAvailability row, with `available` flipped to
  # match the target list. Rows are referenced via JSON:API local ids
  # (${name}); Apple resolves them against the live composite-id rows
  # via the included `territory` relationship.
  lane :set_territories do
    require 'spaceship'
    Spaceship::ConnectAPI.login
    bundle_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("Couldn't find app with bundle id #{bundle_id}") if app.nil?
    target = OKX_AVAILABILITY_ISO3.to_set

    # The parent `appAvailabilities` resource is CREATE-only; once an
    # app has one (always, on existing apps), the only writable path
    # is `POST /v1/bulkUpdateAppAvailabilities`. It overwrites the
    # full set in a single submission, so we have to enumerate every
    # existing territoryAvailability row, flip `available` based on
    # the target list, and pass them all in `included`.
    client = Spaceship::ConnectAPI.client.tunes_request_client
    params = client.build_params(filter: nil, includes: "territory", limit: 200, sort: nil)
    existing = client.get("v2/appAvailabilities/#{app.id}/territoryAvailabilities", params).body["data"]
    UI.message("Bulk-updating #{existing.length} territories: #{target.size} on, #{existing.length - target.size} off")

    rows = existing.map do |row|
      iso3 = row["relationships"]["territory"]["data"]["id"]
      {
        local_id: "${ta_#{iso3}}",
        iso3: iso3,
        available: target.include?(iso3)
      }
    end

    body = {
      data: {
        type: "bulkUpdateAppAvailabilities",
        attributes: { availableInNewTerritories: false },
        relationships: {
          app: { data: { type: "apps", id: app.id } },
          territoryAvailabilities: {
            data: rows.map { |r| { type: "territoryAvailabilities", id: r[:local_id] } }
          }
        }
      },
      included: rows.map do |r|
        {
          type: "territoryAvailabilities",
          id: r[:local_id],
          attributes: { available: r[:available] },
          relationships: {
            territory: { data: { type: "territories", id: r[:iso3] } }
          }
        }
      end
    }
    client.post("v1/bulkUpdateAppAvailabilities", body)
    UI.success("Updated App Store availability — #{target.size} territories enabled.")
  end
end
